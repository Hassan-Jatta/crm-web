generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model commande {
  id_commande      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_contact       String?            @db.Uuid
  montant_total    Decimal            @db.Decimal(10, 2)
  statut_paiement  String?            @db.VarChar(50)
  date_commande    DateTime?          @default(now()) @db.Timestamp(6)
  contact          contact?           @relation(fields: [id_contact], references: [id_contact], onDelete: Cascade, onUpdate: NoAction)
  commande_produit commande_produit[]
}

model commande_produit {
  id_commande           String   @db.Uuid
  id_produit            String   @db.Uuid
  quantite              Int?     @default(1)
  prix_unitaire_facture Decimal  @db.Decimal(10, 2)
  commande              commande @relation(fields: [id_commande], references: [id_commande], onDelete: Cascade, onUpdate: NoAction)
  produit               produit  @relation(fields: [id_produit], references: [id_produit], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_commande, id_produit])
}

model communication {
  id_communication String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_contact       String?   @db.Uuid
  canal            String?   @default("Email") @db.VarChar(50)
  objet_email      String?   @db.VarChar(255)
  taux_ouverture   Decimal?  @db.Decimal(5, 2)
  date_envoi       DateTime? @default(now()) @db.Timestamp(6)
  contact          contact?  @relation(fields: [id_contact], references: [id_contact], onDelete: Cascade, onUpdate: NoAction)
}

model contact {
  id_contact      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom             String          @db.VarChar(100)
  prenom          String          @db.VarChar(100)
  email           String          @unique @db.VarChar(255)
  telephone       String?         @db.VarChar(20)
  pointure        Decimal?        @db.Decimal(3, 1)
  marque_preferee String?         @db.VarChar(100)
  id_entreprise   String?         @db.Uuid
  date_creation   DateTime?       @default(now()) @db.Timestamp(6)
  commande        commande[]
  communication   communication[]
  entreprise      entreprise?     @relation(fields: [id_entreprise], references: [id_entreprise], onUpdate: NoAction)
  lead            lead[]
}

model entreprise {
  id_entreprise    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom_societe      String    @db.VarChar(255)
  secteur_activite String?   @db.VarChar(100)
  type_entreprise  String?   @db.VarChar(50)
  contact          contact[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model lead {
  id_lead        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_contact     String?      @db.Uuid
  id_utilisateur String?      @db.Uuid
  statut         String       @db.VarChar(50)
  source         String?      @db.VarChar(100)
  montant_estime Decimal?     @db.Decimal(10, 2)
  date_creation  DateTime?    @default(now()) @db.Timestamp(6)
  contact        contact?     @relation(fields: [id_contact], references: [id_contact], onDelete: Cascade, onUpdate: NoAction)
  utilisateur    utilisateur? @relation(fields: [id_utilisateur], references: [id_utilisateur], onUpdate: NoAction)
}

model produit {
  id_produit       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modele           String             @db.VarChar(255)
  marque           String             @db.VarChar(100)
  prix_unitaire    Decimal            @db.Decimal(10, 2)
  stock_disponible Int?               @default(0)
  commande_produit commande_produit[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tache {
  id_tache       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_utilisateur String?      @db.Uuid
  titre          String       @db.VarChar(255)
  date_echeance  DateTime?    @db.Timestamp(6)
  statut         String?      @db.VarChar(50)
  date_creation  DateTime?    @default(now()) @db.Timestamp(6)
  utilisateur    utilisateur? @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model utilisateur {
  id_utilisateur String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom_prenom     String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  mot_de_passe   String    @db.VarChar(255)
  role           String    @db.VarChar(50)
  date_creation  DateTime? @default(now()) @db.Timestamp(6)
  lead           lead[]
  tache          tache[]
}
